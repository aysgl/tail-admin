{
  "name": "tailadmin-vue-pro-2.0.1",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx tsx scripts/run.ts \"Dev server\" \"vite\"",
    "build": "yarn run check:deps && yarn run check:format && yarn run check:lint && yarn run check:types && npx tsx scripts/run.ts \"Vite build\" \"vite build\"",
    "fix:format": "npx tsx scripts/run.ts \"Format fix\" \"prettier --write .\"",
    "fix:lint": "npx tsx scripts/run.ts \"Lint fix\" \"eslint . --fix\"",
    "check:deps": "yarn install --frozen-lockfile",
    "check:lint": "npx tsx scripts/run.ts \"Lint\" \"eslint . --format stylish\"",
    "check:format": "npx tsx scripts/run.ts \"Format\" \"prettier --check .\"",
    "check:types": "npx tsx scripts/run.ts \"Type check\" \"vue-tsc --build\"",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "build:chromatic": "npx chromatic --project-token=chpt_a654caf7d2b2fa0",
    "clean:cache": "npx tsx scripts/clean.ts",
    "clean:install": "npx tsx scripts/clean.ts --reinstall && yarn install",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,jsx,mts,mjs}": [
      "prettier --write",
      "eslint --fix --no-warn-ignored"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@fullcalendar/vue3": "^6.1.20",
    "@nuxt/ui": "^4.5.1",
    "@popperjs/core": "^2.11.8",
    "ag-charts-vue3": "^13.1.0",
    "ag-grid-vue3": "^33.0.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@iconify-json/lucide": "^1.2.14",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-designs": "^11.1.2",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/vue3-vite": "^10.2.19",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.3.0",
    "@vue/tsconfig": "^0.7.0",
    "chromatic": "^15.3.0",
    "eslint": "^9.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "lint-staged": "^16.3.3",
    "prettier": "^3.4.2",
    "storybook": "^10.2.19",
    "storybook-vue3-router": "^7.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^6.0.11",
    "vite-plugin-vue-devtools": "^7.7.0",
    "vue-tsc": "^2.2.0"
  }
}
