#!/usr/bin/env sh

GREEN='\033[32m'
RED='\033[31m'
NC='\033[0m'

if ! npx --no -- commitlint --edit "$1" >/dev/null 2>&1; then
  printf "${RED}✗ Commit mesajı formatı başarısız${NC}\n"
  printf "Beklenen format: feat: description veya feat(scope): description\n"
  exit 1
fi
printf "${GREEN}✓ Commit mesajı formatı geçerli${NC}\n"
